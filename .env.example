# ATLAS environment variables
# Copy this file to .env and fill in your keys.
# The system runs in mock mode if keys are absent.

# LLM — Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Market data — FMP (https://financialmodelingprep.com, free tier available)
FMP_API_KEY=

# Market data — Finnhub (https://finnhub.io, free tier available)
FINNHUB_API_KEY=

# Macro data — FRED (https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# Portfolio settings (defaults are sensible)
# STARTING_CAPITAL=1000000
# MAX_POSITION_SIZE_PCT=0.15
# MAX_GROSS_EXPOSURE=1.5
# MAX_NET_EXPOSURE=0.8

# LLM settings
# LLM_MODEL=claude-sonnet-4-6
# LLM_MAX_TOKENS=4096
# LLM_TEMPERATURE=0.3
